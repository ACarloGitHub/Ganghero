{
  "name": "ganghero-bridge",
  "displayName": "Ganghero Bridge",
  "description": "Bridge HTTP locale per Ganghero - connette OpenClaw a VS Code",
  "version": "0.1.0",
  "publisher": "ganghero",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ganghero.start",
        "title": "Ganghero: Avvia Bridge"
      },
      {
        "command": "ganghero.stop",
        "title": "Ganghero: Ferma Bridge"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.0.0"
  }
}
